{
    "name": "yezzmedia/laravel-foundation",
    "description": "Foundation package for the Yezz Media Laravel website platform.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Yezz Media",
            "email": "info@yezzmedia.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "YezzMedia\\Foundation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YezzMedia\\Foundation\\FoundationServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
